# Local development: point at a local Postgres (see README).
# postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL="postgresql://user:pass@localhost:5433/thefacebook?schema=public"

# On Cloud Run, DATABASE_URL uses the Cloud SQL unix socket:
# postgresql://USER:PASSWORD@localhost/DB?host=/cloudsql/PROJECT:REGION:INSTANCE

# Secret used to sign session material.
SESSION_SECRET="change-me"

# Cloud Storage bucket for profile photo uploads (server-side upload).
GCS_BUCKET="omkar-fb-uploads"
